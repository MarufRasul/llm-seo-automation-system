# Optional: extra CORS origins for local dev (comma-separated). Production allows Vercel only.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5000

# GEO measurement (independent evaluators): set GEO_SKIP_LLM_EVAL=1 to skip multi-model API calls
# GEO_SKIP_LLM_EVAL=0
# GEO_EVAL_OPENAI_MODEL=gpt-4o-mini
# GEO_EVAL_ANTHROPIC_MODEL=claude-3-haiku-20240307

OPENAI_API_KEY=your_real_openai_api_key_here
ANTHROPIC_API_KEY=
# Perplexity API (e.g. AI citation tracker)
PERPLEXITY_API_KEY=
SERPAPI_KEY=your_serpapi_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
GITHUB_TOKEN=

GITHUB_REPO=
GITHUB_PAGES_URL=
GITHUB_BRANCH=main
GITHUB_PAGES_CONTENT_DIR=

# Automatic runner settings
AUTO_RUN_MODE=brand_batch
AUTO_RUN_BRANDS=lg_notebook,dongwon_salmon,doshinji_ceramics
AUTO_RUN_TOPICS_PER_BRAND=2
AUTO_RUN_NICHES=LG전자 노트북,동원 연어,도슨티 도자기
